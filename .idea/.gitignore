# -----------------------------------------------------------------------------
# 1. 默认忽略文件 (包含你提供的)
# -----------------------------------------------------------------------------
/shelf/
/workspace.xml

# -----------------------------------------------------------------------------
# 2. Android Studio / IntelliJ IDEA 配置文件
# -----------------------------------------------------------------------------
# 忽略整个 .idea 文件夹是最安全的，但如果团队需要共享配置，可以按需放开特定的 xml
.idea/
*.iml
*.ipr
*.iws
# 本地路径配置，包含本机 Android SDK 路径，绝对不能提交
local.properties

# -----------------------------------------------------------------------------
# 3. Gradle 构建系统
# -----------------------------------------------------------------------------
.gradle/
# 根目录的 build 文件夹
build/
# 各个 module（如 app）下的 build 文件夹
*/build/
# 捕捉根目录以外的其他构建缓存
*/*/build/

# -----------------------------------------------------------------------------
# 4. 编译后的产物与 Android 特有文件
# -----------------------------------------------------------------------------
*.class
*.apk
*.aab
*.ap_
*.dex
*.aar
# C/C++ NDK 编译产物 (以防你的 Java 项目里混入了 NDK)
.cxx/
*.so

# -----------------------------------------------------------------------------
# 5. 安全与密钥 (非常重要)
# -----------------------------------------------------------------------------
# 签名文件绝对不能推送到公开仓库
*.jks
*.keystore
# 如果涉及到极其敏感的线上环境配置，建议把私有属性文件也忽略掉
# private.properties

# -----------------------------------------------------------------------------
# 6. 操作系统生成文件
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# 7. 日志与缓存
# -----------------------------------------------------------------------------
*.log
captures/
# Android Studio Profiler 生成的数据
*.hprof