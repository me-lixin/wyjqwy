<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base layer -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/texture_primary_default" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Overlay layer: 10% geometric texture -->
    <item android:alpha="26" android:drawable="@drawable/bg_texture_pattern_overlay" />
</layer-list>
